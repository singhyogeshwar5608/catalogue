APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Web root where `public/` is served (include port for `php artisan serve`, e.g. http://127.0.0.1:8000).
# Used for payment QR absolute URLs — wrong value = broken QR images on the Next.js dashboard.
APP_URL=http://127.0.0.1:8000
# Payment QR preview URLs are built from APP_URL (not ASSET_URL): /api/v1/v1/stores/{id}/payment-qr-image

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Laravel cache: use `database` (table `cache`) or `redis` (same Redis host, separate logical DB from sessions).
# For fast product-list caching (`Cache::remember` in ProductController), `redis` is recommended when you run Redis.
# `failover` = try Redis, then `database` `cache` table, then in-memory (see config/cache.php). Use this in production
# so missing Redis does not 500 the API. You can set `database` on hosts without Redis at all; use `redis` only when Redis is running.
CACHE_STORE=failover
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# Same Redis for sessions/queues; `database` 0 = default, 1 = cache connection (see config/database.php `redis.cache`).
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Frontend URL for OAuth redirects
FRONTEND_URL=http://localhost:3000

# Required for a correct flow: when Laravel changes stores/products/users, it POSTs here so Next.js / Upstash
# drops `app:stores:*`, `app:products:*`, `app:users:*`. If this is empty, the UI can show deleted DB rows
# until you manually call POST /api/cache/invalidate or flush Redis.
# Must be the **Next.js** origin (where /api/cache/invalidate is served), not your Laravel API host.
# If API is https://api.example.com and the Next frontend is https://app.example.com, use app.example.com here.
# Local:  NEXT_CACHE_INVALIDATE_URL=http://127.0.0.1:3000/api/cache/invalidate
# Live:    NEXT_CACHE_INVALIDATE_URL=https://your-next-frontend.com/api/cache/invalidate
NEXT_CACHE_INVALIDATE_URL=
# Same value as project-root CACHE_INVALIDATE_SECRET; required in production.
NEXT_CACHE_INVALIDATE_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Local: http://localhost:8000/api/v1/auth/google/callback
# Production: https://kaushalschoolfurniture.com/api/v1/auth/google/callback
# Amplify: https://main.d2euv5dilboqrn.amplifyapp.com/api/v1/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Razorpay — subscription checkout (Laravel backend only). Also accepts RZP_LIVE_KEY_ID / RZP_LIVE_KEY_SECRET.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Subscription mock-complete endpoint. Defaults to enabled in `config/services.php` unless set to false.
# Set `false` when you want production to accept only real Razorpay checkouts.
SUBSCRIPTION_MOCK_PAYMENT=true
