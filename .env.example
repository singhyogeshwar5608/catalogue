# Live API (default in code is also this URL if unset). Restart `npm run dev` after edits.
NEXT_PUBLIC_API_BASE_URL=https://kaushalschoolfurniture.com/api/v1/v1

# Local Laravel only (optional):
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api/v1/v1

# If requests still show 127.0.0.1:8000: stop dev server, run `npm run clean` or delete `.next`, then `npm run dev`.

# Optional dev-only same-origin proxy (CORS bypass): NEXT_PUBLIC_USE_API_PROXY=1
# BACKEND_PROXY_TARGET=https://kaushalschoolfurniture.com
